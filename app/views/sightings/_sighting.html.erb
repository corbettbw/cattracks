<div class="text-sm bg-stone-50 border border-stone-200 rounded-lg overflow-hidden">
  <div class="p-3 space-y-2">
    <% if sighting.photo.attached? %>
        <%= link_to url_for(sighting.photo), target: "_blank" do %>
            <%= image_tag sighting.photo, class: "w-full rounded object-cover max-h-48 cursor-pointer" %>
        <% end %>
    <% end %>

    <% if sighting.body.present? %>
      <p class="text-stone-600"><%= sighting.body %></p>
    <% end %>

    <div class="flex justify-between text-stone-400 text-xs pt-1">
      <% if sighting.user %>
        <%= link_to sighting.user&.profile&.display_name || "Anonymous",
              user_path(sighting.user),
              class: "hover:text-amber-700" %>
      <% else %>
        <span>Anonymous</span>
      <% end %>
      <span><%= time_ago_in_words(sighting.created_at) %> ago</span>
    </div>

    <% if sighting.user == Current.user %>
      <div class="flex gap-3 pt-1 border-t border-stone-100">
        <%= link_to "Edit", edit_cat_sighting_path(sighting.cat, sighting),
              class: "text-xs text-amber-700 hover:underline" %>
        <%= button_to "Delete", cat_sighting_path(sighting.cat, sighting), method: :delete,
              data: { turbo_confirm: "Remove this sighting?" },
              class: "text-xs text-red-500 hover:underline bg-transparent border-0 cursor-pointer p-0" %>
      </div>
    <% end %>
  </div>
</div>
<script>
  (function() {
    function initMap(el) {
      if (!el || el._leaflet_id) return;
      const lat = parseFloat(el.dataset.lat);
      const lng = parseFloat(el.dataset.lng);
      if (isNaN(lat) || isNaN(lng)) return;

      L.map(el.id, {
        zoomControl: false,
        dragging: false,
        scrollWheelZoom: false,
        doubleClickZoom: false,
        boxZoom: false,
        keyboard: false,
        touchZoom: false
      }).setView([lat, lng], 15)
        .addLayer(L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
          attribution: "© OpenStreetMap"
        }))
        .addLayer(L.marker([lat, lng]));
    }

    document.querySelectorAll("[id^='map-']").forEach(initMap);
  })();
</script>