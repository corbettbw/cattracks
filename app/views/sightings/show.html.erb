<div class="max-w-lg mx-auto mt-8 space-y-4">
  <div class="flex items-center gap-2 text-sm text-stone-500">
    <%= link_to @cat.name, cat_path(@cat), class: "text-amber-700 hover:underline font-medium" %>
    <span>·</span>
    <span>Sighting</span>
  </div>

  <% if @sighting.lat.present? && @sighting.lng.present? %>
    <div
      id="map-<%= @sighting.id %>"
      style="height: 200px; min-height: 200px;"
      class="w-full rounded-lg overflow-hidden border border-stone-200"
      data-lat="<%= @sighting.lat %>"
      data-lng="<%= @sighting.lng %>">
    </div>
  <% end %>

  <%= render "sightings/sighting", sighting: @sighting, sighting_link: false %>

  <div class="mt-2">
    <%= link_to "← Back to #{@cat.name}", cat_path(@cat), class: "text-sm text-stone-500 hover:underline" %>
  </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  function initSightingMap() {
    const el = document.getElementById("map-<%= @sighting.id %>");
    if (!el || el._leaflet_id) return;

    const lat = parseFloat(el.dataset.lat);
    const lng = parseFloat(el.dataset.lng);

    const map = L.map(el.id, {
      zoomControl: false,
      dragging: false,
      scrollWheelZoom: false,
      doubleClickZoom: false,
      boxZoom: false,
      keyboard: false,
      touchZoom: false
    }).setView([lat, lng], 15);

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: "© OpenStreetMap"
    }).addTo(map);

    L.marker([lat, lng]).addTo(map);
  }

  document.addEventListener("turbo:load", initSightingMap);
  document.addEventListener("DOMContentLoaded", initSightingMap);
</script>