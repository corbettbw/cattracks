<div class="max-w-lg mx-auto mt-8 space-y-4">
  <div class="flex items-center gap-2 text-sm text-stone-500">
    <%= link_to @cat.name, cat_path(@cat), class: "text-amber-700 hover:underline font-medium" %>
    <span>·</span>
    <span>Sighting by <%= @sighting.user&.profile&.display_name || "Anonymous" %></span>
    <span>·</span>
    <span><%= time_ago_in_words(@sighting.created_at) %> ago</span>
  </div>

  <% if @sighting.photo.attached? %>
    <%= image_tag @sighting.photo, class: "w-full rounded-xl object-cover max-h-96" %>
  <% end %>

  <% if @sighting.body.present? %>
    <p class="text-stone-800"><%= @sighting.body %></p>
  <% end %>

  <p class="text-sm text-stone-400">📍 <%= @sighting.lat %>, <%= @sighting.lng %></p>

  <% if @sighting.user == Current.user %>
    <div class="flex gap-4 pt-2 border-t border-stone-100">
      <%= link_to "Edit", edit_cat_sighting_path(@cat, @sighting),
            class: "text-sm text-amber-700 hover:underline" %>
      <%= button_to "Delete", cat_sighting_path(@cat, @sighting), method: :delete,
            data: { turbo_confirm: "Remove this sighting?" },
            class: "text-sm text-red-600 hover:underline bg-transparent border-0 cursor-pointer p-0" %>
    </div>
  <% end %>
</div>