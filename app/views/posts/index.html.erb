<div class="flex justify-between items-center mb-4">
  <h1 class="text-xl font-bold">Feed</h1>
  <%= link_to "+ Post", new_post_path,
        class: "text-sm bg-amber-700 text-white px-3 py-1 rounded hover:bg-amber-800" %>
</div>

<%# Feed mode toggle %>
<div class="flex gap-2 mb-6">
  <%= link_to "Local", posts_path,
        class: "text-sm px-4 py-1.5 rounded-full #{@mode == :local ? 'bg-amber-700 text-white' : 'border border-stone-300 text-stone-600 hover:bg-stone-50'}" %>
  <%= link_to "Following", posts_path(mode: "following"),
        class: "text-sm px-4 py-1.5 rounded-full #{@mode == :following ? 'bg-amber-700 text-white' : 'border border-stone-300 text-stone-600 hover:bg-stone-50'}" %>
</div>

<% if @posts.any? %>
  <div class="space-y-3">
    <%= render @posts %>
  </div>
<% else %>
  <div class="text-center py-12 text-stone-400">
    <% if @mode == :following %>
      <p class="text-sm">You're not following anyone yet.</p>
      <p class="text-sm mt-1">Find people to follow by browsing the local feed.</p>
    <% else %>
      <p class="text-sm">No posts in your area yet.</p>
    <% end %>
  </div>
<% end %>