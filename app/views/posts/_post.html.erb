<div class="bg-white border border-stone-200 rounded-lg p-4 space-y-2">
  <div class="flex items-center gap-2 text-sm text-stone-500">
    <% profile = post.user&.profile %>
    <% if profile&.photo&.attached? %>
      <%= image_tag profile.photo, class: "w-7 h-7 rounded-full object-cover" %>
    <% else %>
      <div class="w-7 h-7 rounded-full bg-stone-200 flex items-center justify-center text-xs">🐾</div>
    <% end %>
    <% if post.user %>
      <%= link_to user_path(post.user), class: "font-medium text-stone-700 hover:text-amber-700" do %>
        <%= profile&.display_name || "Anonymous" %>
      <% end %>
    <% else %>
      <span class="font-medium text-stone-700">Anonymous</span>
    <% end %>
    <span>·</span>
    <span><%= time_ago_in_words(post.created_at) %> ago</span>
    <% if post.sighting? %>
      <span class="ml-auto text-xs bg-amber-100 text-amber-800 px-2 py-0.5 rounded-full">sighting</span>
    <% elsif post.new_cat? %>
      <span class="ml-auto text-xs bg-green-100 text-green-800 px-2 py-0.5 rounded-full">new cat</span>
    <% end %>
  </div>

    <p class="text-stone-800"><%= format_post_body(post) %></p>

  <% if post.sighting? && post.sighting %>
    <% sighting = post.sighting %>
    <% if sighting.photo.attached? %>
      <%= link_to cat_sighting_path(sighting.cat, sighting) do %>
        <%= image_tag sighting.photo, class: "w-full rounded-lg object-cover max-h-72 cursor-pointer" %>
      <% end %>
    <% end %>
  <% end %>

    <% if (post.microblog? || post.new_cat?) && post.photos.attached? %>
    <div class="flex gap-2 flex-wrap mt-2">
        <% post.photos.each do |photo| %>
        <% if post.cats.first %>
            <%= link_to cat_path(post.cats.first) do %>
            <%= image_tag photo, class: "w-full rounded-lg object-cover max-h-72 cursor-pointer" %>
            <% end %>
        <% else %>
            <%= image_tag photo, class: "w-full rounded-lg object-cover max-h-72" %>
        <% end %>
        <% end %>
    </div>
    <% end %>

  <% if post.cats.any? %>
    <div class="flex gap-1 flex-wrap">
      <% post.cats.each do |cat| %>
        <%= link_to "🐾 #{cat.name}", cat_path(cat), class: "text-xs text-amber-700 hover:underline" %>
      <% end %>
    </div>
  <% end %>
  <%# Reply count — only show on top level posts %>
    <% unless post.parent_id? || local_assigns[:hide_reply_link] %>
    <div class="pt-2 border-t border-stone-100">
        <%= link_to post_path(post), class: "text-xs text-stone-400 hover:text-amber-700" do %>
        <% reply_count = post.replies.count %>
        <% if reply_count > 0 %>
            View <%= pluralize(reply_count, "reply") %> →
        <% else %>
            Reply →
        <% end %>
        <% end %>
    </div>
    <% end %>
</div>