<div class="bg-white border border-stone-200 rounded-lg p-4 space-y-2">
  <div class="flex items-center gap-2 text-sm text-stone-500">
    <span class="font-medium text-stone-700">
      <%= post.user&.profile&.display_name || "Anonymous" %>
    </span>
    <span>·</span>
    <span><%= time_ago_in_words(post.created_at) %> ago</span>
    <% if post.sighting? %>
      <span class="ml-auto text-xs bg-amber-100 text-amber-800 px-2 py-0.5 rounded-full">sighting</span>
    <% end %>
  </div>

  <p class="text-stone-800"><%= post.body %></p>

  <% if post.sighting? && post.sighting %>
    <% sighting = post.sighting %>
    <% if sighting.photo.attached? %>
      <%= link_to cat_sighting_path(sighting.cat, sighting) do %>
        <%= image_tag sighting.photo, class: "w-full rounded-lg object-cover max-h-72 cursor-pointer" %>
      <% end %>
    <% end %>
    <p class="text-xs text-stone-400">📍 <%= sighting.lat %>, <%= sighting.lng %></p>
  <% end %>

  <% if post.microblog? && post.photos.attached? %>
    <div class="flex gap-2 flex-wrap mt-2">
      <% post.photos.each do |photo| %>
        <%= image_tag photo, class: "h-48 w-auto rounded object-cover" %>
      <% end %>
    </div>
  <% end %>

  <% if post.cats.any? %>
    <div class="flex gap-1 flex-wrap">
      <% post.cats.each do |cat| %>
        <%= link_to "🐾 #{cat.name}", cat_path(cat), class: "text-xs text-amber-700 hover:underline" %>
      <% end %>
    </div>
  <% end %>
</div>