<div class="max-w-2xl mx-auto space-y-4">
  <%# Original post %>
  <%= render "posts/post", post: @post, hide_reply_link: true %>

  <%# Replies %>
  <% if @replies.any? %>
    <div class="space-y-2">
      <h2 class="text-sm font-semibold text-stone-500 uppercase tracking-wide">
        <%= pluralize(@replies.count, "reply") %>
      </h2>
      <% @replies.each do |reply| %>
        <div class="ml-4 border-l-2 border-stone-200 pl-4">
          <%= render "posts/post", post: reply, hide_reply_link: true %>
          <% if reply.replies.any? %>
            <div class="mt-2 space-y-2">
              <% reply.replies.order(created_at: :asc).each do |nested_reply| %>
                <div class="ml-4 border-l-2 border-stone-100 pl-4">
                  <%= render "posts/post", post: nested_reply, hide_reply_link: true %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Reply form %>
  <div class="bg-white border border-stone-200 rounded-lg p-4">
    <h2 class="text-sm font-semibold text-stone-600 mb-3">Leave a reply</h2>
    <%= form_with model: @reply, url: posts_path, multipart: true do |f| %>
      <%= f.hidden_field :parent_id, value: @post.id %>
      <div class="space-y-3">
        <div class="relative" data-controller="mention">
          <%= f.text_area :body,
                placeholder: "Write a reply... Use @ to tag a person, $ to tag a cat",
                rows: 3,
                data: {
                  mention_target: "input",
                  action: "input->mention#onInput keydown->mention#onKeydown"
                },
                class: "w-full border border-stone-300 rounded px-3 py-2 text-sm" %>
          <div data-mention-target="dropdown"
               class="hidden absolute z-10 bg-white border border-stone-200 rounded shadow-lg w-64 mt-1">
          </div>
        </div>
        <div class="flex items-center justify-between">
          <%= f.file_field :photos, multiple: true, accept: "image/*",
                class: "text-sm text-stone-600" %>
          <%= f.submit "Reply",
                class: "bg-amber-700 text-white px-4 py-1.5 rounded text-sm hover:bg-amber-800" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-2">
    <%= link_to "← Back to feed", posts_path, class: "text-sm text-stone-500 hover:underline" %>
  </div>
</div>