<!DOCTYPE html>
<html>
  <head>
    <title>Cat Tracks</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-stone-50 text-stone-800 min-h-screen">
    <%= render "shared/navbar" %>
    <main class="max-w-2xl mx-auto px-4 py-6">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>
    <footer class="mt-12 py-6 border-t border-stone-200 text-center text-xs text-stone-400 space-x-4">
      <%= link_to "Terms of Service", tos_path, class: "hover:text-stone-600" %>
      <%= link_to "Privacy Policy", privacy_policy_path, class: "hover:text-stone-600" %>
      <%= link_to "Support Us", support_path, class: "hover:text-stone-600" %>
      <span>© <%= Date.today.year %> Cat Tracks</span>
  </footer>
  </body>
</html>