<nav class="bg-amber-800 text-amber-50 px-4 py-3 flex items-center justify-between">
  <%# Left %>
  <div class="flex items-center gap-4 w-1/4">
    <%= link_to "🐾 Cat Tracks", root_path, class: "font-bold text-lg tracking-tight hover:text-amber-200" %>
    <% if authenticated? %>
      <%= link_to "Browse", browse_path, class: "text-sm hover:text-amber-200" %>
    <% end %>
  </div>

  <%# Center %>
  <div class="flex-1 flex justify-center px-4">
    <% if authenticated? %>
      <%= form_with url: search_path, method: :get, class: "flex items-center w-full max-w-md" do |f| %>
        <%= f.text_field :q,
      placeholder: "Search people and cats...",
      class: "text-stone-800 placeholder-stone-400 bg-amber-50 text-sm px-3 py-1.5 rounded-l w-full focus:outline-none focus:bg-white" %>
        <%= f.submit "🔍",
              class: "bg-amber-600 hover:bg-amber-500 px-3 py-1.5 rounded-r text-sm cursor-pointer border-0" %>
      <% end %>
    <% end %>
  </div>

<%# Right %>
  <div class="flex items-center gap-4 text-sm w-1/4 justify-end">
    <%= link_to "Support Us", support_path, class: "text-sm hover:text-amber-200" %>
    <% if authenticated? %>
      <% unread_count = Current.user.notifications.unread.count %>
      <%= link_to notifications_path, class: "relative hover:text-amber-200" do %>
        🔔
        <% if unread_count > 0 %>
          <span class="absolute -top-1 -right-2 bg-red-500 text-white text-xs rounded-full w-4 h-4 flex items-center justify-center leading-none">
            <%= unread_count > 9 ? "9+" : unread_count %>
          </span>
        <% end %>
      <% end %>
      <%= link_to user_path(Current.user), class: "flex items-center gap-2 hover:text-amber-200" do %>
        <% if Current.user.profile&.photo&.attached? %>
          <%= image_tag Current.user.profile.photo, class: "w-7 h-7 rounded-full object-cover" %>
        <% else %>
          <div class="w-7 h-7 rounded-full bg-amber-600 flex items-center justify-center text-xs">🐾</div>
        <% end %>
        <span class="text-sm"><%= "My Profile" %></span>
      <% end %>      
      <%= button_to "Sign out", session_path, method: :delete,
            data: { turbo: false },
            class: "hover:text-amber-200 bg-transparent border-0 cursor-pointer p-0 text-sm text-amber-50" %>
    <% else %>
      <%= link_to "Sign in", new_session_path, class: "hover:text-amber-200" %>
      <%= link_to "Join", new_user_path,
            class: "bg-amber-600 hover:bg-amber-500 px-3 py-1 rounded font-medium" %>
    <% end %>
  </div>
</nav>