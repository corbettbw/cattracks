<div class="space-y-6">
  <%# Header %>
  <div class="flex gap-4 items-start">
    <% if @cat.profile_photo.attached? %>
      <%= image_tag @cat.profile_photo, class: "w-24 h-24 rounded-xl object-cover" %>
    <% else %>
      <div class="w-24 h-24 rounded-xl bg-amber-100 flex items-center justify-center text-4xl">🐈</div>
    <% end %>
    <div class="flex-1">
      <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold"><%= @cat.name %></h1>
        <% if @cat.caregivers.include?(Current.user) || @cat.created_by == Current.user.id %>
          <%= link_to "Edit", edit_cat_path(@cat),
                class: "text-sm text-amber-700 hover:underline" %>
        <% end %>
      </div>
      <p class="text-sm text-stone-500 capitalize"><%= @cat.status %></p>
      <p class="text-stone-700 mt-1"><%= @cat.bio %></p>
    </div>
  </div>

  <%# Caregivers %>
  <div>
    <h2 class="font-semibold mb-2">Caregivers</h2>
    <% if @cat.caregivers.any? %>
      <div class="flex gap-2 flex-wrap">
        <% @cat.caregivers.each do |caregiver| %>
          <span class="text-sm bg-stone-100 px-2 py-1 rounded">
            <%= caregiver.profile&.display_name || "Anonymous" %>
          </span>
        <% end %>
      </div>
      <div class="mt-2 flex gap-3">
        <% if @cat.caregivers.include?(Current.user) %>
          <%= button_to "Leave as caregiver", leave_cat_path(@cat), method: :delete,
                data: { turbo_confirm: "Are you sure? You'll need to be re-added by another caregiver." },
                class: "text-sm text-red-600 border border-red-300 px-3 py-1 rounded hover:bg-red-50" %>
        <% else %>
          <%= button_to "Become a caregiver", claim_cat_path(@cat),
                class: "text-sm text-amber-700 border border-amber-700 px-3 py-1 rounded hover:bg-amber-50" %>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-stone-500 mb-2">No caregivers yet.</p>
      <%= button_to "Claim this cat", claim_cat_path(@cat),
            class: "text-sm bg-amber-700 text-white px-3 py-1 rounded hover:bg-amber-800" %>
    <% end %>
  </div>

  <%# Sightings %>
  <div>
    <div class="flex items-center justify-between mb-2">
      <h2 class="font-semibold">Sightings</h2>
      <%= link_to "+ Log a sighting", new_cat_sighting_path(@cat),
            class: "text-sm text-amber-700 hover:underline" %>
    </div>

    <% if @cat.sightings.any? %>
      <%# Multi-pin map — inline style required for Leaflet to detect height %>
      <div
        id="cat-sightings-map"
        style="height: 256px; min-height: 256px;"
        class="w-full rounded-lg overflow-hidden border border-stone-200 mb-4"
        data-sightings="<%= @cat.sightings.order(created_at: :desc).map { |s|
          {
            id: s.id,
            lat: s.lat,
            lng: s.lng,
            body: s.body,
            time: time_ago_in_words(s.created_at),
            url: cat_sighting_path(@cat, s),
            photo: s.photo.attached? ? url_for(s.photo) : nil
          }
        }.to_json %>">
      </div>

      <%# Sighting cards %>
      <div class="space-y-3">
        <% @cat.sightings.order(created_at: :desc).each do |sighting| %>
          <%= link_to cat_sighting_path(@cat, sighting), class: "block hover:opacity-90 transition-opacity" do %>
            <%= render "sightings/sighting", sighting: sighting, sighting_link: false %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-stone-500">No sightings logged yet.</p>
    <% end %>
  </div>

  <%# Photo gallery %>
  <% if @cat.pictures.attached? %>
    <div>
      <h2 class="font-semibold mb-2">Photos</h2>
      <div class="grid grid-cols-3 gap-2">
        <% @cat.pictures.each do |picture| %>
          <%= image_tag picture, class: "w-full aspect-square object-cover rounded-lg" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  function initCatMap() {
    const el = document.getElementById("cat-sightings-map");
    if (!el || el._leaflet_id) return;

    const sightings = JSON.parse(el.dataset.sightings);
    if (!sightings.length) return;

    const first = sightings[0];
    const map = L.map("cat-sightings-map", {
      zoomControl: true,
      dragging: true,
      scrollWheelZoom: false
    }).setView([first.lat, first.lng], 14);

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: "© OpenStreetMap"
    }).addTo(map);

    sightings.forEach(function (s) {
      const marker = L.marker([s.lat, s.lng]).addTo(map);

      let popupHtml = '<div style="max-width:180px">';
      if (s.photo) {
        popupHtml += `<a href="${s.url}"><img src="${s.photo}" style="width:100%;border-radius:6px;margin-bottom:6px;object-fit:cover;max-height:100px"></a>`;
      }
      if (s.body) {
        popupHtml += `<p style="font-size:12px;margin:0 0 4px">${s.body}</p>`;
      }
      popupHtml += `<p style="font-size:11px;color:#aaa;margin:0 0 6px">${s.time} ago</p>`;
      popupHtml += `<a href="${s.url}" style="font-size:12px;color:#b45309;text-decoration:underline">View sighting →</a>`;
      popupHtml += '</div>';

      marker.bindPopup(popupHtml);
    });

    if (sightings.length > 1) {
      const bounds = L.latLngBounds(sightings.map(s => [s.lat, s.lng]));
      map.fitBounds(bounds, { padding: [30, 30] });
    }
  }

  document.addEventListener("turbo:load", initCatMap);
  document.addEventListener("DOMContentLoaded", initCatMap);
</script>