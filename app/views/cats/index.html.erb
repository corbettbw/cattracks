<div class="flex justify-between items-center mb-6">
  <h1 class="text-xl font-bold">Cats in Your Area</h1>
  <%= link_to "+ Add a cat", new_cat_path,
        class: "text-sm bg-amber-700 text-white px-3 py-1 rounded hover:bg-amber-800" %>
</div>

<% if @unclaimed_cats.any? %>
  <div class="mb-6">
    <h2 class="text-sm font-semibold text-stone-500 uppercase tracking-wide mb-2">Looking for a caregiver</h2>
    <div class="space-y-2">
      <%= render @unclaimed_cats %>
    </div>
  </div>
<% end %>

<div class="space-y-2">
  <%= render @cats %>
</div>